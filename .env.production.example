# Copy to /home/SnapEvents/.env on the VPS and fill in real values

# Docker images (auto-set by CI/CD - can override manually)
API_IMAGE=ghcr.io/GITHUB_USERNAME/snapevents-api:latest
FRONTEND_IMAGE=ghcr.io/GITHUB_USERNAME/snapevents-frontend:latest

# MongoDB
MONGODB_CONNECTION_STRING=mongodb://m115:PASSWORD@mongodb.mikr.dev:27017/db_m115
MONGODB_DATABASE_NAME=db_m115
MONGODB_CLIENTS_COLLECTION=Clients

# Google Cloud
GOOGLE_PROJECT_ID=weddingphotos-441512

# CORS - your production domain
ALLOWED_ORIGINS=https://twoja-domena.pl

# Admin panel credentials (change before production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong-password-here
ADMIN_JWT_SECRET=random-256-bit-secret-here

# Hangfire
HANGFIRE_ENABLED=true
HANGFIRE_DASHBOARD_ENABLED=false
HANGFIRE_DASHBOARD_USERNAME=admin
HANGFIRE_DASHBOARD_PASSWORD=strong-password-here

# Optional
SENTRY_DSN=
DISCORD_WEBHOOK_URL=
